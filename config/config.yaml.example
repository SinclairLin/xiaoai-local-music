# Copy this file to config.yaml and replace the values as needed.
xiaomi_user: "your-xiaomi-user"
xiaomi_password: "your-xiaomi-password"
# mina_mode: "mock" 或 "miservice"（直连小米云）
mina_mode: "mock"
mina_device_id: "mock-device"
public_base_url: "http://nas-host:8123"
music_root: "/music"
host: "0.0.0.0"
port: 8123
voice:
  enabled: false
  poll_interval_sec: 1.5
  hijack_all_play: true
  speak_confirm: true
  hardware: "LX06"
voice:
  enabled: false
  poll: 1.5
  hijack: true
  speak: true
  hardware: "auto"
