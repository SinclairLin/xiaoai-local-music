services:
  xiaoai-local-music:
    image: ghcr.io/sinclairlin/xiaoai-local-music:latest
    container_name: xiaoai-local-music
    restart: unless-stopped
    ports:
      - "8123:8123"
    environment:
      MUSIC_ROOT: /music
      CONFIG_DIR: /config
      PUBLIC_BASE_URL: ${PUBLIC_BASE_URL:?set PUBLIC_BASE_URL to an address reachable by the speaker}
      MINA_DEVICE_ID: ${MINA_DEVICE_ID:-}
      PORT: "8123"
    volumes:
      - ${MUSIC_HOST_DIR:-/path/to/music}:/music:ro
      - ${CONFIG_HOST_DIR:-./config}:/config
